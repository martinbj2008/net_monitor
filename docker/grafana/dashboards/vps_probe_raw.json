{
  "uid": "vps-probe-raw",
  "title": "VPS Probe - Raw Samples (single link)",
  "tags": ["vps_probe", "smokeping", "raw"],
  "timezone": "${tz}",
  "schemaVersion": 39,
  "version": 2,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "tz",
        "type": "custom",
        "label": "Timezone",
        "description": "Dashboard display timezone. Data is stored in UTC in DB; this only affects axis labels.",
        "query": "UTC,Asia/Shanghai",
        "current": { "text": "UTC", "value": "UTC" },
        "options": [
          { "text": "UTC",           "value": "UTC",           "selected": true  },
          { "text": "Asia/Shanghai", "value": "Asia/Shanghai", "selected": false }
        ]
      },
      {
        "name": "src",
        "type": "query",
        "label": "Source",
        "datasource": { "type": "postgres", "uid": "probe-pg" },
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "query": "SELECT DISTINCT src FROM probe_sample ORDER BY 1",
        "sort": 1
      },
      {
        "name": "dst",
        "type": "query",
        "label": "Destination",
        "datasource": { "type": "postgres", "uid": "probe-pg" },
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "query": "SELECT DISTINCT dst FROM probe_sample WHERE src = '$src' ORDER BY 1",
        "sort": 1
      },
      {
        "name": "proto",
        "type": "query",
        "label": "Protocol",
        "datasource": { "type": "postgres", "uid": "probe-pg" },
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "query": "SELECT DISTINCT proto FROM probe_sample ORDER BY 1",
        "sort": 1
      },
      {
        "name": "ipver",
        "type": "custom",
        "label": "IP Version",
        "description": "Filter lines. 'all' shows v4 and v6 side by side; 4 or 6 hides the other family.",
        "query": "all,4,6",
        "current": { "text": "all", "value": "all" },
        "options": [
          { "text": "all", "value": "all", "selected": true  },
          { "text": "4",   "value": "4",   "selected": false },
          { "text": "6",   "value": "6",   "selected": false }
        ]
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Smokeping (raw) - $src → $dst  ($proto, ipver=$ipver)",
      "datasource": { "type": "postgres", "uid": "probe-pg" },
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 0 },
      "description": "Per-sample view: each dot = one probe sample (no aggregation). Blue = v4 RTT, Orange = v6 RTT. Red X on the right axis marks failed samples (loss).",
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT ts AS \"time\",\n       CASE WHEN ok AND ip_ver=4 THEN rtt_ms END AS \"rtt_v4\",\n       CASE WHEN ok AND ip_ver=6 THEN rtt_ms END AS \"rtt_v6\",\n       CASE WHEN NOT ok AND ip_ver=4 THEN 0 END AS \"fail_v4\",\n       CASE WHEN NOT ok AND ip_ver=6 THEN 0 END AS \"fail_v6\"\nFROM probe_sample\nWHERE $__timeFilter(ts)\n  AND src = '$src' AND dst = '$dst'\n  AND proto = '$proto'\n  AND ('$ipver' = 'all' OR ip_ver::text = '$ipver')\nORDER BY ts"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 0,
            "showPoints": "always",
            "pointSize": 4,
            "spanNulls": false,
            "axisPlacement": "left"
          },
          "unit": "ms"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "rtt_v4" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#3274d9" } },
              { "id": "displayName", "value": "v4 rtt" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "rtt_v6" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#ff9830" } },
              { "id": "displayName", "value": "v6 rtt" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "fail_v4" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.axisLabel", "value": "loss" },
              { "id": "custom.drawStyle", "value": "points" },
              { "id": "custom.pointSize", "value": 8 },
              { "id": "custom.showPoints", "value": "always" },
              { "id": "custom.lineWidth", "value": 0 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#e02f44" } },
              { "id": "max", "value": 1 },
              { "id": "min", "value": 0 },
              { "id": "displayName", "value": "v4 fail" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "fail_v6" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.axisLabel", "value": "loss" },
              { "id": "custom.drawStyle", "value": "points" },
              { "id": "custom.pointSize", "value": 10 },
              { "id": "custom.showPoints", "value": "always" },
              { "id": "custom.lineWidth", "value": 0 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#c00020" } },
              { "id": "max", "value": 1 },
              { "id": "min", "value": 0 },
              { "id": "displayName", "value": "v6 fail" }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    }
  ]
}
